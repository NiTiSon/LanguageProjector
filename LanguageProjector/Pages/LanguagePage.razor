@page "/language/{Id:guid}"
@using LanguageProjector.Logic
@using LanguageProjector.Services
@using LanguageProjector.Components.Language
@inject LocalStorageService Storage
@inject NavigationManager Navigation

<div class="flex h-[calc(100vh-4rem)] overflow-hidden">
    @if (_language is null)
    {
        <div class="flex items-center justify-center flex-1">
            <div class="text-center">
                <p class="text-lg text-base-content/60">Language not found.</p>
                <a href="/dashboard" class="btn btn-primary mt-4">Back to Dashboard</a>
            </div>
        </div>
    }
    else
    {
        <aside class="w-56 lg:w-64 shrink-0 border-r border-base-300 bg-base-200 p-4 flex flex-col gap-1">
            <div class="px-3 py-2 mb-2">
                <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50">Categories</p>
            </div>

            <button class="@NavButtonClass(Section.Language)" @onclick='() => _activeSection = Section.Language'>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.78.147 2.653.255m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802"/>
                </svg>
                Language
            </button>

            <button class="@HeaderButtonClass()" @onclick="TogglePhonetics">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform duration-200 @(_phoneticsExpanded ? "rotate-90" : "")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                </svg>
                Phonetics
            </button>

            @if (_phoneticsExpanded)
            {
                <button class="@SubNavButtonClass(Section.Phonemes)" @onclick='() => _activeSection = Section.Phonemes'>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z"/>
                    </svg>
                    Phonemes
                </button>
            }
        </aside>

        <main class="flex-1 p-6 overflow-y-auto">
            @switch (_activeSection)
            {
                case Section.Language:
                    <LanguageInfo Lang="_language" SaveAsync="SaveAsync" />
                    break;
                case Section.Phonemes:
                    <PhonemeList Lang="_language" SaveAsync="SaveAsync" />
                    break;
            }
        </main>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Language? _language;
    private Section _activeSection = Section.Language;
    private bool _phoneticsExpanded = false;

    protected override async Task OnInitializedAsync()
    {
        var languages = await Storage.GetLanguagesAsync();
        _language = languages.FirstOrDefault(l => l.Id == Id);
    }

    private async Task SaveAsync()
    {
        if (_language is null) return;
        _language.LastModified = DateTime.UtcNow;
        var languages = await Storage.GetLanguagesAsync();
        var index = languages.FindIndex(l => l.Id == _language.Id);
        if (index >= 0)
        {
            languages[index] = _language;
            await Storage.SaveLanguagesAsync(languages);
        }
    }

    private void TogglePhonetics()
    {
        _phoneticsExpanded = !_phoneticsExpanded;
        if (_phoneticsExpanded && _activeSection is Section.Language)
            _activeSection = Section.Phonemes;
    }

    private string NavButtonClass(Section section) =>
        $"flex items-center gap-3 w-full px-3 py-2 text-sm rounded-lg transition-colors cursor-pointer text-left {(_activeSection == section ? "bg-base-300 text-base-content font-semibold" : "text-base-content/70 hover:bg-base-300/50 hover:text-base-content")}";

    private string HeaderButtonClass() =>
        $"flex items-center gap-3 w-full px-3 py-2 text-sm rounded-lg transition-colors cursor-pointer text-left text-base-content/70 hover:bg-base-300/50 hover:text-base-content";

    private string SubNavButtonClass(Section section) =>
        $"flex items-center gap-3 w-full pl-10 pr-3 py-1.5 text-sm rounded-lg transition-colors cursor-pointer text-left {(_activeSection == section ? "bg-base-300 text-base-content font-semibold" : "text-base-content/60 hover:bg-base-300/50 hover:text-base-content")}";

    private enum Section
    {
        Language,
        Phonemes
    }
}
