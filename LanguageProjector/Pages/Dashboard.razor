    private List<LanguageSummary> _languages = [];

    protected override void OnInitialized()
    {
        LoadLanguages();
    }

    private void LoadLanguages()
    {
        #if DEBUG
        _languages = [
            new LanguageSummary(Guid.CreateVersion7(), "Ananas", 10, DateTime.Now)
        ];
        #endif
    }

    private void CreateLanguage()
    {
