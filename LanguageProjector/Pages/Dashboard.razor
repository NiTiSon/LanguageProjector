@page "/dashboard"

<div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold">Dashboard</h1>
            <p class="text-base-content/70 mt-1">Manage your constructed languages</p>
        </div>
        <div class="flex gap-3">
            <button class="btn btn-outline" @onclick="Import">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                </svg>
                Import
            </button>
        </div>
    </div>

    @if (languages.Count == 0)
    {
        <div class="card bg-base-200 border border-base-300">
            <div class="card-body items-center text-center py-16">
                <div class="text-base-content/30 mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                    </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">No languages yet</h3>
                <p class="text-base-content/60 max-w-md mb-6">
                    Start by creating your first language or import an existing one from a file.
                </p>
                <div class="flex gap-3">
                    <button class="btn btn-primary" @onclick="CreateLanguage">Create Language</button>
                    <button class="btn btn-outline" @onclick="Import">Import Language</button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Words</th>
                        <th>Last Modified</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lang in languages)
                    {
                        <tr>
                            <td class="font-medium">@lang.Name</td>
                            <td>@lang.WordCount</td>
                            <td>@lang.LastModified.ToShortDateString()</td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-ghost" title="Export"
                                        @onclick="() => ExportLanguage(lang.Id)">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10.5v6m0 0-3-3m3 3 3-3m2 8H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z" />
                                    </svg>
                                </button>
                                <button class="btn btn-sm btn-ghost btn-square text-error" title="Delete"
                                        @onclick="() => DeleteLanguage(lang.Id)">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private record LanguageSummary(Guid Id, string Name, int WordCount, DateTime LastModified);

    private List<LanguageSummary> languages = [];

    protected override void OnInitialized()
    {
        LoadLanguages();
    }

    private void LoadLanguages()
    {
        languages = [];
    }

    private void CreateLanguage()
    {
    }

    private async Task ExportLanguage(Guid id)
    {
        await Task.CompletedTask;
    }

    private async Task ExportAll()
    {
        await Task.CompletedTask;
    }

    private async Task Import()
    {
        await Task.CompletedTask;
    }

    private void DeleteLanguage(Guid id)
    {
    }
}
