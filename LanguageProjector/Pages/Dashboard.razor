@page "/dashboard"
@using LanguageProjector.Logic
@using LanguageProjector.Services
@inject IJSRuntime Js
@inject LocalStorageService Storage
@inject NavigationManager Navigation

<div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold">Dashboard</h1>
            <p class="text-base-content/70 mt-1">Manage your constructed languages</p>
        </div>
        <div class="flex gap-3">
            <button class="btn btn-outline" @onclick="Import">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                </svg>
                Import
            </button>
            <button class="btn btn-primary" @onclick="CreateLanguage">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Create New
            </button>
        </div>
    </div>

    @if (_languages.Count == 0)
    {
        <div class="card bg-base-200 border border-base-300">
            <div class="card-body items-center text-center py-16">
                <div class="text-base-content/30 mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                    </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">No languages yet</h3>
                <p class="text-base-content/60 max-w-md mb-6">
                    Start by creating your first language or import an existing one from a file.
                </p>
                <div class="flex gap-3">
                    <button class="btn btn-primary" @onclick="CreateLanguage">Create Language</button>
                    <button class="btn btn-outline" @onclick="Import">Import Language</button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="grid gap-4 md:grid-cols-2">
            @foreach (var lang in _languages)
            {
                <div class="card bg-base-100 border border-base-300 cursor-pointer hover:shadow-lg transition-shadow"
                     @onclick="() => EditLanguage(lang.Id)">
                    <div class="card-body p-5">
                        <div class="flex items-start justify-between">
                            <div class="min-w-0">
                                <h3 class="card-title text-lg truncate">@lang.Name</h3>
                                <small class="text-sm text-base-content/60 mt-1">@lang.Words.Count words</small>
                            </div>
                            <div class="dropdown dropdown-end" @onclick:stopPropagation>
                                <button class="btn btn-sm btn-ghost btn-square" tabindex="0" role="button">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
                                    </svg>
                                </button>
                                <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-40 p-2 shadow border border-base-300">
                                    <li><a @onclick="() => ExportLanguage(lang.Id)">Export</a></li>
                                    <li><a @onclick="() => DeleteLanguage(lang.Id)" class="text-error">Delete</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="mt-3 flex items-center gap-2">
                            <span class="text-xs text-base-content/40">Modified @FormatDate(lang.LastModified)</span>
                            <button class="btn btn-sm btn-ghost ml-auto text-primary"
                                    @onclick="() => EditLanguage(lang.Id)"
                                    @onclick:stopPropagation>
                                Edit
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<dialog id="create-modal" class="modal">
    <div class="modal-box">
        <form @onsubmit="ConfirmCreate">
            <h3 class="text-lg font-bold">Create Language</h3>
            <input type="text" @bind="_newLanguageName" @bind:event="oninput"
                    placeholder="Language name" class="input w-full mt-4 focus:outline-none" />
            <div class="modal-action">
                <button type="submit" class="btn btn-primary">Create</button>
                <button type="button" class="btn" @onclick="CloseCreateModal">Cancel</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<dialog id="delete-modal" class="modal">
    <div class="modal-box">
        <h3 class="text-lg font-bold">Delete Language</h3>
        <p class="py-4">
            Are you sure you want to delete <strong>@_languageToDelete?.Name</strong>?
            This action cannot be undone.
        </p>
        <div class="modal-action">
            <button class="btn btn-error" @onclick="ConfirmDelete">Delete</button>
            <button class="btn" @onclick="CloseDeleteModal">Cancel</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button @onclick="CloseDeleteModal">close</button>
    </form>
</dialog>

@code {
    private List<Language> _languages = [];

    protected override async Task OnInitializedAsync()
    {
        _languages = await Storage.GetLanguagesAsync();
    }

    private string _newLanguageName = "";

    private async Task CreateLanguage()
    {
        _newLanguageName = "";
        await Js.InvokeVoidAsync("showModal", "create-modal");
    }

    private async Task ConfirmCreate()
    {
        var name = _newLanguageName?.Trim();
        if (string.IsNullOrEmpty(name)) return;

        var lang = Language.Create(name);
        _languages.Add(lang);
        await CloseCreateModal();
        await Storage.SaveLanguagesAsync(_languages);
    }

    private async Task CloseCreateModal()
    {
        await Js.InvokeVoidAsync("closeModal", "create-modal");
    }

    private async Task ExportLanguage(Guid id)
    {
        await Task.CompletedTask;
    }

    private async Task Import()
    {
        await Task.CompletedTask;
    }

    private Language? _languageToDelete;

    private async Task DeleteLanguage(Guid id)
    {
        _languageToDelete = _languages.FirstOrDefault(l => l.Id == id);
        if (_languageToDelete is null) return;
        await Js.InvokeVoidAsync("showModal", "delete-modal");
    }

    private async Task ConfirmDelete()
    {
        if (_languageToDelete is null) return;
        _languages.RemoveAll(l => l == _languageToDelete);
        await Storage.SaveLanguagesAsync(_languages);
        await CloseDeleteModal();
    }

    private async Task CloseDeleteModal()
    {
        await Js.InvokeVoidAsync("closeModal", "delete-modal");
    }

    private void EditLanguage(Guid id)
    {
        Navigation.NavigateTo($"/language/{id}");
    }

    private static string FormatDate(DateTime dt) => dt.ToLocalTime().ToLongDateString();
}
